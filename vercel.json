{
  "rewrites": [
    { "source": "/__/auth/(.*)", "destination": "https://routed-c5b0c.firebaseapp.com/__/auth/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
